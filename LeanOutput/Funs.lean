def util.inz (value : Std.U8) : Result Std.U8 := do
  let value1 ← lift (UScalar.cast .U16 value)
  let i ← lift (~~~ value1)
  let i1 ← lift (core.num.U16.wrapping_add i 1#u16)
  let i2 ← lift (value1 ||| i1)
  let i3 ← i2 >>> 8#i32
  let result ← lift (i3 &&& 1#u16)
  ok (UScalar.cast .U8 result)

